---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceBadge from "../../components/EvidenceBadge.astro";
import { events, evidenceFor, getEventSources } from "../../lib/records.js";

export function getStaticPaths() {
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const evidence = evidenceFor(event);
const linkedSources = getEventSources(event);
const canonical = new URL(`/record/${event.id}/`, Astro.site).href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: event.title,
  description: event.summary,
  datePublished: String(event.year),
  dateModified: String(event.year),
  mainEntityOfPage: canonical,
  publisher: { "@type": "Organization", name: "LetsFixIndia", url: "https://www.letsfixindia.com" },
};
---
<BaseLayout title={`${event.title} | LetsFixIndia`} description={event.summary} canonical={canonical}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <div class="page-shell">
    <a class="read-record" href="/timeline">← Back to the record</a>
    <header class="record-header"><p class="eyebrow">{event.date || event.year} · {event.category}</p><h1>{event.title}</h1><EvidenceBadge evidence={evidence} /></header>
    <div class="record-layout">
      <article class="record-story">
        <h2>What happened</h2><p>{event.summary}</p>
        <h2>What happened next</h2><p>{event.outcome}</p>
        <h2>How to read this record</h2><p>The evidence label describes the state of the linked source ledger, not a verdict on the event. Open the cited material and read it in context.</p>
      </article>
      <aside class="record-aside" id="sources"><p class="eyebrow">Documentation</p><h2>Sources for this record</h2>
        {linkedSources.length ? linkedSources.map((source, index) => source.url ? <a class="source-link source-motion" data-source-motion style={`--reveal-delay: ${index * 75}ms`} href={source.url} target="_blank" rel="noopener noreferrer"><span class="source-reference">Source {String(index + 1).padStart(2, "0")}</span>{source.publisher}: {source.title} <span aria-hidden="true">↗</span></a> : <span class="source-pending source-motion" data-source-motion style={`--reveal-delay: ${index * 75}ms`}>{source.publisher}: link pending</span>) : <span class="source-pending">No linked source record yet.</span>}
        <a class="button button-secondary" href={`/submit?record=${encodeURIComponent(event.id)}`}>Suggest a correction</a>
      </aside>
    </div>
  </div>
</BaseLayout>
