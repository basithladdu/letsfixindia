---
import SpaShell from "../components/SpaShell.astro";

export function getStaticPaths() {
  const namedRoutes = [
    "timeline",
    "landing",
    "gallery",
    "gallery/submit",
    "map",
    "states",
    "statistics",
    "indicators",
    "voices",
    "sources",
    "submit",
    "submissions",
    "faq",
    "methodology",
    "contact",
    "support",
    "partner",
    "donors",
    "about"
  ].map((route) => ({ params: { route } }));

  return [{ params: { route: undefined } }, ...namedRoutes];
}
---
<SpaShell />
